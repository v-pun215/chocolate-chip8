{
  "version": 4,
  "configurations": [
    {
      "name": "Mac",
      "compilerPath": "/opt/homebrew/bin/g++-15",
      "intelliSenseMode": "macos-gcc-arm64",
      "cppStandard": "c++17",
      "cStandard": "c17",
      "includePath": [
        "${workspaceFolder}/**",
        "/opt/homebrew/include",
        "/opt/homebrew/opt/sdl2/include",
        "/opt/homebrew/opt/sdl2/include/SDL2"
      ],
      "macFrameworkPath": [
        "/System/Library/Frameworks",
        "/Library/Frameworks"
      ]
    },
    {
      "name": "Linux",
      "compilerPath": "/usr/bin/g++",
      "intelliSenseMode": "linux-gcc-x64",
      "cppStandard": "c++17",
      "cStandard": "c17",
      "includePath": [
        "${workspaceFolder}/**"
      ]
    }
  ]
}